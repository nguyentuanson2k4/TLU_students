// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===================== ENUMS =====================

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PostRecipientType {
  ALL_STUDENTS
  SPECIFIC_CLASSES
  BY_DEPARTMENT
}

enum Role {
  ADMIN
  STUDENT
  LECTURER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Degree {
  BACHELOR
  MASTER
  PHD
}

enum AttendanceMethod {
  FACE_ID
  MANUAL
  QR_CODE
}

enum SenderType {
  USER
  BOT
}

enum WarningSeverity {
  Low
  Medium
  High
}

enum TuitionStatus {
  UNPAID
  PAID
  OVERDUE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

// ===================== CORE USER MODELS =====================

model User {
  id                     BigInt    @id @default(autoincrement())
  username               String    @unique @db.VarChar(255)
  password               String    @db.VarChar(255)
  role                   Role      @default(STUDENT)
  is_active              Boolean   @default(true)
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  refresh_token          String?   @db.VarChar(255)
  avatar_url             String?   @db.VarChar(500)
  reset_password_otp     String?   @db.VarChar(10)
  reset_password_expires DateTime?

  student  Student?
  lecturer Lecturer?

  // Reverse relations
  attendanceUpdates AttendanceRecord[] @relation("AttendanceUpdater")
  chatSessions      ChatSession[]
  posts             Post[]
  conversationsAs1  Conversation[]     @relation("User1Conversations")
  conversationsAs2  Conversation[]     @relation("User2Conversations")
  directMessages    DirectMessage[]
  serviceRequests   ServiceRequest[]
  warningLogs       WarningLog[]
  notifications     Notification[]
  fcmTokens         FcmToken[]

  @@map("users")
}

model Student {
  id              BigInt   @id @default(autoincrement())
  user_id         BigInt   @unique
  student_code    String   @unique @db.VarChar(50)
  full_name       String   @db.VarChar(255)
  dob             DateTime
  gender          Gender
  phone_number    String   @db.VarChar(20)
  class_name      String   @db.VarChar(50)
  address         String?  @db.VarChar(255)
  gpa             Decimal? @db.Decimal(3, 2)
  email           String   @unique @db.VarChar(255)
  major_name      String?  @db.VarChar(255)
  department_name String?  @db.VarChar(255)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Reverse relations
  enrollments       ClassEnrollment[]
  gpaHistories      GpaHistory[]
  attendanceRecords AttendanceRecord[]
  tuitionFees       TuitionFee[]
  faces             StudentFace[]

  @@map("students")
}

model Lecturer {
  id            BigInt   @id @default(autoincrement())
  user_id       BigInt   @unique
  lecturer_code String   @unique @db.VarChar(50)
  full_name     String   @db.VarChar(255)
  department    String   @db.VarChar(255)
  phone_number  String   @db.VarChar(20)
  email         String   @unique @db.VarChar(255)
  major_name    String?  @db.VarChar(255)
  degree        Degree
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Reverse relations
  courseClasses CourseClass[]

  @@map("lecturers")
}

// ===================== ACADEMIC MODELS =====================

model Subject {
  id           BigInt  @id @default(autoincrement())
  subject_code String  @unique @db.VarChar(50)
  subject_name String  @db.VarChar(255)
  credits      Int
  description  String? @db.VarChar(255)

  // Reverse relations
  courseClasses CourseClass[]

  @@map("subjects")
}

model Semester {
  id                 BigInt  @id @default(autoincrement())
  semester_name      String  @db.VarChar(50)
  academic_year      String  @db.VarChar(20)
  tuition_per_credit Decimal @default(0) @db.Decimal(15, 2) // VND per credit

  // Reverse relations
  courseClasses CourseClass[]
  gpaHistories  GpaHistory[]
  tuitionFees   TuitionFee[]

  @@map("semesters")
}

model CourseClass {
  id               BigInt   @id @default(autoincrement())
  subject_id       BigInt
  lecturer_id      BigInt
  semester_id      BigInt
  room             String?  @db.VarChar(50)
  latitude         Float?
  longitude        Float?
  allowed_radius   Int?     @default(50)
  max_students     Int?
  current_students Int?
  day_of_week      Int      @db.SmallInt
  lesson_slot      String   @db.VarChar(50)
  start_date       DateTime @db.Date
  end_date         DateTime @db.Date
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  subject  Subject  @relation(fields: [subject_id], references: [id])
  lecturer Lecturer @relation(fields: [lecturer_id], references: [id])
  semester Semester @relation(fields: [semester_id], references: [id])

  // Reverse relations
  enrollments        ClassEnrollment[]
  attendanceSessions AttendanceSession[]
  posts              Post[]

  @@index([subject_id])
  @@index([lecturer_id])
  @@index([semester_id])
  @@map("course_classes")
}

model ClassEnrollment {
  id              BigInt @id @default(autoincrement())
  student_id      BigInt
  course_class_id BigInt

  student      Student     @relation(fields: [student_id], references: [id], onDelete: Cascade)
  course_class CourseClass @relation(fields: [course_class_id], references: [id], onDelete: Cascade)

  // Reverse relations
  grades Grade[]

  @@unique([student_id, course_class_id])
  @@index([student_id])
  @@index([course_class_id])
  @@map("class_enrollments")
}

model Grade {
  id               BigInt   @id @default(autoincrement())
  enrollment_id    BigInt
  score_attendance Decimal  @default(0) @db.Decimal(4, 2)
  score_process    Decimal  @default(0) @db.Decimal(4, 2)
  score_final      Decimal  @default(0) @db.Decimal(4, 2)
  score_total_10   Decimal  @default(0.00) @db.Decimal(4, 2)
  updated_at       DateTime @updatedAt

  enrollment ClassEnrollment @relation(fields: [enrollment_id], references: [id], onDelete: Cascade)

  @@index([enrollment_id])
  @@map("grades")
}

model GpaHistory {
  id             BigInt   @id @default(autoincrement())
  student_id     BigInt
  semester_id    BigInt
  gpa_semester   Decimal  @default(0.00) @db.Decimal(3, 2)
  gpa_cumulative Decimal  @default(0.00) @db.Decimal(3, 2)
  updated_at     DateTime @updatedAt

  student  Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  semester Semester @relation(fields: [semester_id], references: [id])

  @@unique([student_id, semester_id])
  @@index([student_id])
  @@index([semester_id])
  @@map("gpa_history")
}

// ===================== FACE RECOGNITION MODELS =====================

model StudentFace {
  id               BigInt                      @id @default(autoincrement())
  student_id       BigInt
  image_url        String                      @db.VarChar(500)
  embedding_vector Unsupported("vector(512)")?
  created_at       DateTime                    @default(now())

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id])
  @@map("student_faces")
}

// ===================== ATTENDANCE MODELS =====================

model AttendanceSession {
  id               BigInt    @id @default(autoincrement())
  course_class_id  BigInt
  check_in_time    DateTime? @db.Time
  date             DateTime? @db.Date
  is_reminder_sent         Boolean   @default(false)
  is_auto_absent_processed Boolean   @default(false)

  course_class CourseClass @relation(fields: [course_class_id], references: [id], onDelete: Cascade)

  // Reverse relations
  records AttendanceRecord[]

  @@index([course_class_id])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id                 BigInt           @id @default(autoincrement())
  session_id         BigInt
  student_id         BigInt
  arrival_time       DateTime?
  status             Int              @db.SmallInt
  confidence_score   Float            @default(0)
  is_manual_override Boolean          @default(false)
  evidence_url       String?          @db.VarChar(500)
  attendance_method  AttendanceMethod @default(FACE_ID)
  updated_by         BigInt?
  note               String?          @db.Text
  created_at         DateTime         @default(now())

  session AttendanceSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  student Student           @relation(fields: [student_id], references: [id], onDelete: Cascade)
  updater User?             @relation("AttendanceUpdater", fields: [updated_by], references: [id])

  @@unique([session_id, student_id])
  @@index([session_id])
  @@index([student_id])
  @@map("attendance_records")
}

// ===================== CHAT / AI MODELS =====================

model ChatSession {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt
  start_time DateTime  @default(now())
  end_time   DateTime?
  status     Int       @default(1) @db.SmallInt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Reverse relations
  messages ChatMessage[]

  @@index([user_id])
  @@map("chat_sessions")
}

model ChatMessage {
  id              BigInt     @id @default(autoincrement())
  session_id      BigInt
  sender_type     SenderType
  message_content String?    @db.Text
  created_at      DateTime   @default(now())

  session ChatSession @relation(fields: [session_id], references: [id])

  @@index([session_id])
  @@map("chat_messages")
}

model KnowledgeBase {
  id                   BigInt   @id @default(autoincrement())
  document_name        String?  @db.VarChar(500)
  file_path            String?  @db.VarChar(500)
  vector_db_collection String?  @db.VarChar(100)
  status               Boolean  @default(false)
  created_at           DateTime @default(now())

  // Reverse relations
  chunks DocumentChunk[]

  @@map("knowledge_base")
}

model DocumentChunk {
  id                BigInt                       @id @default(autoincrement())
  knowledge_base_id BigInt
  content           String                       @db.Text
  embedding         Unsupported("vector(3072)")?
  chunk_index       Int
  created_at        DateTime                     @default(now())

  knowledgeBase KnowledgeBase @relation(fields: [knowledge_base_id], references: [id], onDelete: Cascade)

  @@index([knowledge_base_id])
  @@map("document_chunks")
}

model AiModelConfig {
  id            BigInt  @id @default(autoincrement())
  model_name    String? @db.VarChar(100)
  temperature   Float   @default(0.7)
  api_key_alias String? @db.VarChar(255)
  version       String? @db.VarChar(50)

  @@map("ai_model_config")
}

// ===================== ANNOUNCEMENT / POST MODELS =====================

model Post {
  id              BigInt            @id @default(autoincrement())
  author_id       BigInt
  course_class_id BigInt?
  title           String            @db.VarChar(255)
  content         String?           @db.Text
  post_type       Int               @default(1) @db.SmallInt
  recipient_type  PostRecipientType @default(SPECIFIC_CLASSES)
  recipient_ids   String?           @db.Text // JSON array of IDs (class IDs, etc.)
  status          PostStatus        @default(PUBLISHED)
  published_at    DateTime?         @default(now())
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  author       User         @relation(fields: [author_id], references: [id], onDelete: Cascade)
  course_class CourseClass? @relation(fields: [course_class_id], references: [id], onDelete: Cascade)

  // Reverse relations
  media         PostMedia[]
  notifications Notification[]

  @@index([author_id])
  @@index([course_class_id])
  @@index([status])
  @@index([published_at])
  @@map("posts")
}

model PostMedia {
  id        BigInt  @id @default(autoincrement())
  post_id   BigInt
  file_url  String  @db.VarChar(500)
  file_type String? @db.VarChar(50)

  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@index([post_id])
  @@map("post_media")
}

// ===================== MESSAGING MODELS =====================

model Conversation {
  id              BigInt    @id @default(autoincrement())
  user_id_1       BigInt
  user_id_2       BigInt
  last_message_at DateTime?

  user1 User @relation("User1Conversations", fields: [user_id_1], references: [id], onDelete: Cascade)
  user2 User @relation("User2Conversations", fields: [user_id_2], references: [id], onDelete: Cascade)

  // Reverse relations
  messages DirectMessage[]

  @@unique([user_id_1, user_id_2])
  @@index([user_id_1])
  @@index([user_id_2])
  @@map("conversations")
}

model DirectMessage {
  id              BigInt   @id @default(autoincrement())
  conversation_id BigInt
  sender_id       BigInt
  content         String?  @db.Text
  message_type    String   @default("TEXT") @db.VarChar(20)
  media_url       String?  @db.VarChar(500)
  is_deleted      Boolean  @default(false)
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now())

  conversation Conversation @relation(fields: [conversation_id], references: [id])
  sender       User         @relation(fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([conversation_id])
  @@index([sender_id])
  @@map("direct_messages")
}

// ===================== SERVICE / ADMIN MODELS =====================

model DocumentType {
  id              BigInt  @id @default(autoincrement())
  document_name   String? @db.VarChar(255)
  processing_days Int?    @db.SmallInt

  // Reverse relations
  serviceRequests ServiceRequest[]

  @@map("document_types")
}

model ServiceRequest {
  id               BigInt   @id @default(autoincrement())
  user_id          BigInt
  document_type_id BigInt
  reason           String?  @db.VarChar(500)
  attachment_url   String?  @db.VarChar(500)
  status           Int      @default(1) @db.SmallInt
  created_at       DateTime @default(now())

  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  documentType DocumentType @relation(fields: [document_type_id], references: [id])

  @@index([user_id])
  @@index([document_type_id])
  @@map("service_requests")
}

model WarningLog {
  id          BigInt          @id @default(autoincrement())
  user_id     BigInt
  category    String?         @db.VarChar(100)
  severity    WarningSeverity
  content     String?         @db.Text
  is_resolved Boolean         @default(false)
  created_at  DateTime        @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("warning_logs")
}

model Notification {
  id                BigInt   @id @default(autoincrement())
  user_id           BigInt
  title             String?  @db.VarChar(255)
  message           String?  @db.Text
  notification_type String?  @db.VarChar(50)
  source_id         BigInt?
  is_read           Boolean  @default(false)
  fcm_sent          Boolean  @default(false)
  created_at        DateTime @default(now())

  user User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [source_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([source_id])
  @@map("notifications")
}

model FcmToken {
  id          BigInt   @id @default(autoincrement())
  user_id     BigInt
  token       String   @db.VarChar(500)
  device_name String?  @db.VarChar(255)
  platform    String?  @db.VarChar(50) // android, ios, web
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, token])
  @@index([user_id])
  @@index([token])
  @@map("fcm_tokens")
}

// ===================== TUITION MODELS =====================

model TuitionFee {
  id              BigInt        @id @default(autoincrement())
  student_id      BigInt
  semester_id     BigInt
  total_amount    Decimal       @db.Decimal(15, 2)
  discount_amount Decimal       @default(0) @db.Decimal(15, 2)
  final_amount    Decimal       @db.Decimal(15, 2) // total_amount - discount_amount
  deadline        DateTime
  status          TuitionStatus @default(UNPAID)

  // Payment info (filled after payment)
  payment_method String?        @db.VarChar(50) // VNPAY, MOMO, CASH, TRANSFER...
  transaction_id String?        @unique @db.VarChar(100)
  vnp_txn_ref    String?        @unique @db.VarChar(100) // Mã giao dịch gửi lên VNPay
  payment_status PaymentStatus?
  paid_at        DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  student  Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  semester Semester @relation(fields: [semester_id], references: [id])

  @@unique([student_id, semester_id])
  @@index([student_id])
  @@index([semester_id])
  @@index([status])
  @@map("tuition_fees")
}
