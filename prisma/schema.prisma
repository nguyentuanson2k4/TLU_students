// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===================== ENUMS =====================

enum Role {
  ADMIN
  STUDENT
  LECTURER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Degree {
  BACHELOR
  MASTER
  PHD
}

enum AttendanceMethod {
  FACE_ID
  MANUAL
  QR_CODE
}

enum SenderType {
  USER
  BOT
}

enum WarningSeverity {
  Low
  Medium
  High
}

// ===================== CORE USER MODELS =====================

model User {
  id        BigInt   @id @default(autoincrement())
  username  String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      Role     @default(STUDENT)
  is_active Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  refresh_token String? @db.VarChar(255)
  reset_password_otp     String?  @db.VarChar(10)
  reset_password_expires DateTime?

  student  Student?
  lecturer Lecturer?

  // Reverse relations
  attendanceUpdates AttendanceRecord[] @relation("AttendanceUpdater")
  chatSessions      ChatSession[]
  posts             Post[]
  postInteractions  PostInteraction[]
  conversationsAs1  Conversation[]     @relation("User1Conversations")
  conversationsAs2  Conversation[]     @relation("User2Conversations")
  directMessages    DirectMessage[]
  serviceRequests   ServiceRequest[]
  warningLogs       WarningLog[]
  notifications     Notification[]

  @@map("users")
}

model Student {
  id                 BigInt   @id @default(autoincrement())
  user_id            BigInt   @unique
  student_code       String   @unique @db.VarChar(50)
  full_name          String   @db.VarChar(255)
  dob                DateTime
  gender             Gender
  phone_number       String   @db.VarChar(20)
  class_name         String   @db.VarChar(50)
  address            String?  @db.VarChar(255)
  gpa                Decimal? @db.Decimal(3, 2)
  vector_db_ref      String?  @db.VarChar(255)
  is_face_registered Boolean  @default(false)
  email              String   @unique @db.VarChar(255)
  major_name         String?  @db.VarChar(255)
  department_name    String?  @db.VarChar(255)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  // Reverse relations
  enrollments       ClassEnrollment[]
  grades            Grade[]
  gpaHistories      GpaHistory[]
  attendanceRecords AttendanceRecord[]
  tuitionFees       TuitionFee[]

  @@map("students")
}

model Lecturer {
  id            BigInt   @id @default(autoincrement())
  user_id       BigInt   @unique
  lecturer_code String   @unique @db.VarChar(50)
  full_name     String   @db.VarChar(255)
  department    String   @db.VarChar(255)
  phone_number  String   @db.VarChar(20)
  email         String   @unique @db.VarChar(255)
  major_name    String?  @db.VarChar(255)
  degree        Degree
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  // Reverse relations
  courseClasses CourseClass[]

  @@map("lecturers")
}

// ===================== ACADEMIC MODELS =====================

model Subject {
  id           BigInt @id @default(autoincrement())
  subject_code String @unique @db.VarChar(50)
  subject_name String @db.VarChar(255)
  credits      Int
  description  String? @db.VarChar(255)

  // Reverse relations
  courseClasses CourseClass[]
  posts        Post[]

  @@map("subjects")
}

model Semester {
  id            BigInt @id @default(autoincrement())
  semester_name String @db.VarChar(50)
  academic_year String @db.VarChar(20)

  // Reverse relations
  courseClasses CourseClass[]
  gpaHistories GpaHistory[]
  tuitionFees  TuitionFee[]

  @@map("semesters")
}

model CourseClass {
  id               BigInt   @id @default(autoincrement())
  subject_id       BigInt
  lecturer_id      BigInt
  semester_id      BigInt
  academic_year    String   @db.VarChar(20)
  room             String?  @db.VarChar(50)
  max_students     Int?
  current_students Int?
  day_of_week      Int      @db.SmallInt
  lesson_slot      String   @db.VarChar(50)
  start_date       DateTime @db.Date
  end_date         DateTime @db.Date
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  subject  Subject  @relation(fields: [subject_id], references: [id])
  lecturer Lecturer @relation(fields: [lecturer_id], references: [id])
  semester Semester @relation(fields: [semester_id], references: [id])

  // Reverse relations
  enrollments        ClassEnrollment[]
  grades             Grade[]
  attendanceSessions AttendanceSession[]
  posts              Post[]

  @@index([subject_id])
  @@index([lecturer_id])
  @@index([semester_id])
  @@map("course_classes")
}

model ClassEnrollment {
  id              BigInt @id @default(autoincrement())
  student_id      BigInt
  course_class_id BigInt

  student      Student     @relation(fields: [student_id], references: [id])
  course_class CourseClass @relation(fields: [course_class_id], references: [id])

  // Reverse relations
  grades Grade[]

  @@unique([student_id, course_class_id])
  @@index([student_id])
  @@index([course_class_id])
  @@map("class_enrollments")
}

model Grade {
  id               BigInt   @id @default(autoincrement())
  student_id       BigInt
  course_class_id  BigInt
  enrollment_id    BigInt
  score_attendance Decimal  @default(0) @db.Decimal(4, 2)
  score_process    Decimal  @default(0) @db.Decimal(4, 2)
  score_final      Decimal  @default(0) @db.Decimal(4, 2)
  score_total_10   Decimal  @default(0.00) @db.Decimal(4, 2)
  updated_at       DateTime @updatedAt

  student      Student         @relation(fields: [student_id], references: [id])
  course_class CourseClass     @relation(fields: [course_class_id], references: [id])
  enrollment   ClassEnrollment @relation(fields: [enrollment_id], references: [id])

  @@index([student_id])
  @@index([course_class_id])
  @@index([enrollment_id])
  @@map("grades")
}

model GpaHistory {
  id             BigInt   @id @default(autoincrement())
  student_id     BigInt
  semester_id    BigInt
  gpa_semester   Decimal  @default(0.00) @db.Decimal(3, 2)
  gpa_cumulative Decimal  @default(0.00) @db.Decimal(3, 2)
  updated_at     DateTime @updatedAt

  student  Student  @relation(fields: [student_id], references: [id])
  semester Semester @relation(fields: [semester_id], references: [id])

  @@unique([student_id, semester_id])
  @@index([student_id])
  @@index([semester_id])
  @@map("gpa_history")
}

// ===================== ATTENDANCE MODELS =====================

model AttendanceSession {
  id              BigInt    @id @default(autoincrement())
  course_class_id BigInt
  check_in_time   DateTime? @db.Time
  date            DateTime? @db.Date

  course_class CourseClass @relation(fields: [course_class_id], references: [id])

  // Reverse relations
  records AttendanceRecord[]

  @@index([course_class_id])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id                 BigInt           @id @default(autoincrement())
  session_id         BigInt
  student_id         BigInt
  arrival_time       DateTime?
  status             Int              @db.SmallInt
  confidence_score   Float            @default(0)
  is_manual_override Boolean          @default(false)
  evidence_url       String?          @db.VarChar(500)
  attendance_method  AttendanceMethod @default(FACE_ID)
  updated_by         BigInt?
  note               String?          @db.Text
  created_at         DateTime         @default(now())

  session AttendanceSession @relation(fields: [session_id], references: [id])
  student Student           @relation(fields: [student_id], references: [id])
  updater User?             @relation("AttendanceUpdater", fields: [updated_by], references: [id])

  @@unique([session_id, student_id])
  @@index([session_id])
  @@index([student_id])
  @@map("attendance_records")
}

// ===================== CHAT / AI MODELS =====================

model ChatSession {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt
  start_time DateTime  @default(now())
  end_time   DateTime?
  status     Int       @default(1) @db.SmallInt

  user User @relation(fields: [user_id], references: [id])

  // Reverse relations
  messages ChatMessage[]

  @@index([user_id])
  @@map("chat_sessions")
}

model ChatMessage {
  id              BigInt     @id @default(autoincrement())
  session_id      BigInt
  sender_type     SenderType
  message_content String?    @db.Text
  created_at      DateTime   @default(now())

  session ChatSession @relation(fields: [session_id], references: [id])

  // Reverse relations
  entities  ChatEntity[]
  analyses  ChatHistoryAnalysis[]

  @@index([session_id])
  @@map("chat_messages")
}

model ChatIntent {
  id          BigInt  @id @default(autoincrement())
  intent_name String? @db.VarChar(255)
  description String? @db.VarChar(500)

  // Reverse relations
  analyses     ChatHistoryAnalysis[]
  templates    SystemResponseTemplate[]
  workflows    WorkflowMapping[]
  trainingData AiTrainingDataset[]

  @@map("chat_intents")
}

model ChatEntity {
  id           BigInt  @id @default(autoincrement())
  message_id   BigInt
  entity_type  String? @db.VarChar(100)
  entity_value String? @db.VarChar(255)

  message ChatMessage @relation(fields: [message_id], references: [id])

  @@index([message_id])
  @@map("chat_entities")
}

model ChatHistoryAnalysis {
  id               BigInt @id @default(autoincrement())
  message_id       BigInt
  confidence_score Float?
  intent_id        BigInt

  message ChatMessage @relation(fields: [message_id], references: [id])
  intent  ChatIntent  @relation(fields: [intent_id], references: [id])

  @@index([message_id])
  @@index([intent_id])
  @@map("chat_history_analysis")
}

model SystemResponseTemplate {
  id            BigInt  @id @default(autoincrement())
  intent_id     BigInt
  template_text String? @db.Text

  intent ChatIntent @relation(fields: [intent_id], references: [id])

  @@index([intent_id])
  @@map("system_response_templates")
}

model WorkflowMapping {
  id           BigInt  @id @default(autoincrement())
  intent_id    BigInt
  action_name  String? @db.VarChar(100)
  target_table String? @db.VarChar(100)

  intent ChatIntent @relation(fields: [intent_id], references: [id])

  @@index([intent_id])
  @@map("workflow_mapping")
}

model KnowledgeBase {
  id                   BigInt  @id @default(autoincrement())
  document_name        String? @db.VarChar(500)
  file_path            Bytes?
  vector_db_collection String? @db.VarChar(100)
  status               Boolean @default(false)

  @@map("knowledge_base")
}

model AiTrainingDataset {
  id              BigInt   @id @default(autoincrement())
  sample_question String?  @db.Text
  intent_id       BigInt
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())

  intent ChatIntent @relation(fields: [intent_id], references: [id])

  @@index([intent_id])
  @@map("ai_training_dataset")
}

model AiModelConfig {
  id            BigInt  @id @default(autoincrement())
  model_name    String? @db.VarChar(100)
  temperature   Float   @default(0.7)
  api_key_alias String? @db.VarChar(255)
  version       String? @db.VarChar(50)

  @@map("ai_model_config")
}

// ===================== COMMUNITY / POST MODELS =====================

model Post {
  id              BigInt   @id @default(autoincrement())
  author_id       BigInt
  course_class_id BigInt?
  subject_id      BigInt?
  title           String   @db.VarChar(255)
  content         String?  @db.Text
  post_type       Int      @default(1) @db.SmallInt
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  author       User         @relation(fields: [author_id], references: [id])
  course_class CourseClass? @relation(fields: [course_class_id], references: [id])
  subject      Subject?     @relation(fields: [subject_id], references: [id])

  // Reverse relations
  media        PostMedia[]
  interactions PostInteraction[]

  @@index([author_id])
  @@index([course_class_id])
  @@index([subject_id])
  @@map("posts")
}

model PostMedia {
  id        BigInt  @id @default(autoincrement())
  post_id   BigInt
  file_url  String  @db.VarChar(500)
  file_type String? @db.VarChar(50)

  post Post @relation(fields: [post_id], references: [id])

  @@index([post_id])
  @@map("post_media")
}

model PostInteraction {
  id         BigInt   @id @default(autoincrement())
  post_id    BigInt
  user_id    BigInt
  type       String?  @db.VarChar(20)
  created_at DateTime @default(now())

  post Post @relation(fields: [post_id], references: [id])
  user User @relation(fields: [user_id], references: [id])

  @@unique([post_id, user_id, type])
  @@index([post_id])
  @@index([user_id])
  @@map("post_interaction")
}

// ===================== MESSAGING MODELS =====================

model Conversation {
  id              BigInt    @id @default(autoincrement())
  user_id_1       BigInt
  user_id_2       BigInt
  last_message_at DateTime?

  user1 User @relation("User1Conversations", fields: [user_id_1], references: [id])
  user2 User @relation("User2Conversations", fields: [user_id_2], references: [id])

  // Reverse relations
  messages DirectMessage[]

  @@unique([user_id_1, user_id_2])
  @@index([user_id_1])
  @@index([user_id_2])
  @@map("conversations")
}

model DirectMessage {
  id              BigInt   @id @default(autoincrement())
  conversation_id BigInt
  sender_id       BigInt
  content         String?  @db.Text
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now())

  conversation Conversation @relation(fields: [conversation_id], references: [id])
  sender       User         @relation(fields: [sender_id], references: [id])

  @@index([conversation_id])
  @@index([sender_id])
  @@map("direct_messages")
}

// ===================== SERVICE / ADMIN MODELS =====================

model DocumentType {
  id              BigInt  @id @default(autoincrement())
  document_name   String? @db.VarChar(255)
  processing_days Int?    @db.SmallInt

  // Reverse relations
  serviceRequests ServiceRequest[]

  @@map("document_types")
}

model ServiceRequest {
  id               BigInt   @id @default(autoincrement())
  user_id          BigInt
  document_type_id BigInt
  reason           String?  @db.VarChar(500)
  attachment_url   String?  @db.VarChar(500)
  status           Int      @default(1) @db.SmallInt
  created_at       DateTime @default(now())

  user         User         @relation(fields: [user_id], references: [id])
  documentType DocumentType @relation(fields: [document_type_id], references: [id])

  @@index([user_id])
  @@index([document_type_id])
  @@map("service_requests")
}

model WarningLog {
  id          BigInt          @id @default(autoincrement())
  user_id     BigInt
  category    String?         @db.VarChar(100)
  severity    WarningSeverity
  content     String?         @db.Text
  is_resolved Boolean         @default(false)
  created_at  DateTime        @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("warning_logs")
}

model Notification {
  id                BigInt   @id @default(autoincrement())
  user_id           BigInt
  title             String?  @db.VarChar(255)
  message           String?  @db.Text
  notification_type String?  @db.VarChar(50)
  source_id         BigInt?
  is_read           Boolean  @default(false)
  created_at        DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("notifications")
}

// ===================== TUITION MODELS =====================

model TuitionFee {
  id              BigInt   @id @default(autoincrement())
  student_id      BigInt
  semester_id     BigInt
  total_amount    Decimal  @db.Decimal(15, 2)
  discount_amount Decimal  @default(0) @db.Decimal(15, 2)
  deadline        DateTime
  status          Int      @default(1) @db.SmallInt

  student  Student  @relation(fields: [student_id], references: [id])
  semester Semester @relation(fields: [semester_id], references: [id])

  // Reverse relations
  payments TuitionPayment[]

  @@unique([student_id, semester_id])
  @@index([student_id])
  @@index([semester_id])
  @@map("tuition_fees")
}

model TuitionPayment {
  id             BigInt   @id @default(autoincrement())
  tuition_fee_id BigInt
  amount_paid    Decimal  @db.Decimal(15, 2)
  payment_method String   @db.VarChar(50)
  transaction_id String   @unique @db.VarChar(100)
  payment_date   DateTime @default(now())

  tuitionFee TuitionFee @relation(fields: [tuition_fee_id], references: [id])

  @@index([tuition_fee_id])
  @@map("tuition_payments")
}